{% extends 'base.html.twig' %}

{% block title %}Create Account{% endblock %}

{% block body %}
<div class="container" style="max-width: 420px; margin-top: 3rem;">
    <div class="card">
        <h2 style="text-align: center; margin-bottom: 0.5rem;">Create account</h2>
        <p style="text-align: center; color: var(--text-muted); margin-bottom: 1.5rem;">Join EventHub</p>

        <div id="status-message"></div>

        <!-- Auth method tabs -->
        <div class="auth-tabs" style="display: flex; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border);">
            <button type="button" class="auth-tab active" data-method="passkey" style="flex: 1; padding: 0.75rem; background: transparent; border: none; color: var(--text); cursor: pointer; border-bottom: 2px solid var(--accent);">🔐 Passkey</button>
            <button type="button" class="auth-tab" data-method="password" style="flex: 1; padding: 0.75rem; background: transparent; border: none; color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent;">🔑 Password</button>
        </div>

        <!-- Passkey registration form -->
        <form id="passkey-form" class="auth-form">
            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" id="pk-username" class="form-control" placeholder="johndoe" required>
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" id="pk-email" class="form-control" placeholder="you@example.com" required>
            </div>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
                Use your device's biometrics (fingerprint, face) or security key to create a secure passkey.
            </p>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Create with Passkey</button>
        </form>

        <!-- Password registration form (hidden by default) -->
        <form id="password-form" class="auth-form" style="display: none;">
            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" id="pw-username" class="form-control" placeholder="johndoe" required>
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" id="pw-email" class="form-control" placeholder="you@example.com" required>
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" id="pw-password" class="form-control" placeholder="Min 6 characters" minlength="6" required>
            </div>
            <div class="form-group">
                <label class="form-label">Confirm Password</label>
                <input type="password" id="pw-password-confirm" class="form-control" placeholder="Confirm password" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Create Account</button>
        </form>

        <p style="text-align: center; margin-top: 1.5rem; color: var(--text-muted); font-size: 0.9rem;">
            Already have an account? <a href="{{ path('auth_login') }}">Sign in</a>
        </p>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="/js/webauthn.js"></script>
<script>
// Tab switching
document.querySelectorAll('.auth-tab').forEach(tab => {
    tab.addEventListener('click', function() {
        document.querySelectorAll('.auth-tab').forEach(t => {
            t.classList.remove('active');
            t.style.borderBottomColor = 'transparent';
            t.style.color = 'var(--text-muted)';
        });
        this.classList.add('active');
        this.style.borderBottomColor = 'var(--accent)';
        this.style.color = 'var(--text)';
        
        const method = this.dataset.method;
        document.getElementById('passkey-form').style.display = method === 'passkey' ? 'block' : 'none';
        document.getElementById('password-form').style.display = method === 'password' ? 'block' : 'none';
    });
});

// Passkey registration
document.getElementById('passkey-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const statusDiv = document.getElementById('status-message');
    const button = this.querySelector('button[type="submit"]');
    
    const username = document.getElementById('pk-username').value.trim();
    const email = document.getElementById('pk-email').value.trim();
    
    button.disabled = true;
    button.textContent = 'Creating passkey...';
    statusDiv.innerHTML = '<div class="alert alert-info">Requesting passkey creation...</div>';
    
    try {
        // Step 1: Get registration options
        const optionsRes = await fetch('/api/auth/passkey/register/options', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, email })
        });
        const optionsData = await optionsRes.json();
        
        if (!optionsRes.ok) throw new Error(optionsData.error || 'Failed to get options');
        
        // Step 2: Create credential with WebAuthn
        statusDiv.innerHTML = '<div class="alert alert-info">Complete the passkey prompt on your device...</div>';
        const credential = await createCredential(optionsData.options);
        
        // Step 3: Verify with server
        statusDiv.innerHTML = '<div class="alert alert-info">Verifying...</div>';
        const verifyRes = await fetch('/api/auth/passkey/register/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: optionsData.user_id, credential })
        });
        const verifyData = await verifyRes.json();
        
        if (!verifyRes.ok) throw new Error(verifyData.error || 'Verification failed');
        
        statusDiv.innerHTML = '<div class="alert alert-success">Account created! Redirecting...</div>';
        setTimeout(() => window.location.href = verifyData.redirect || '/', 1000);
        
    } catch (error) {
        button.disabled = false;
        button.textContent = 'Create with Passkey';
        
        if (error.name === 'NotAllowedError') {
            statusDiv.innerHTML = '<div class="alert alert-error">Passkey creation was cancelled or not supported. Try the Password method instead.</div>';
        } else {
            statusDiv.innerHTML = '<div class="alert alert-error">' + error.message + '</div>';
        }
    }
});

// Password registration
document.getElementById('password-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const statusDiv = document.getElementById('status-message');
    const button = this.querySelector('button[type="submit"]');
    
    const username = document.getElementById('pw-username').value.trim();
    const email = document.getElementById('pw-email').value.trim();
    const password = document.getElementById('pw-password').value;
    const passwordConfirm = document.getElementById('pw-password-confirm').value;
    
    if (password !== passwordConfirm) {
        statusDiv.innerHTML = '<div class="alert alert-error">Passwords do not match</div>';
        return;
    }
    
    button.disabled = true;
    button.textContent = 'Creating...';
    statusDiv.innerHTML = '<div class="alert alert-info">Creating account...</div>';
    
    try {
        const response = await fetch('/api/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, email, password })
        });
        const data = await response.json();
        
        if (!response.ok) throw new Error(data.error || 'Registration failed');
        
        statusDiv.innerHTML = '<div class="alert alert-success">Account created! Redirecting...</div>';
        setTimeout(() => window.location.href = data.redirect || '/', 1000);
        
    } catch (error) {
        button.disabled = false;
        button.textContent = 'Create Account';
        statusDiv.innerHTML = '<div class="alert alert-error">' + error.message + '</div>';
    }
});
</script>
{% endblock %}
