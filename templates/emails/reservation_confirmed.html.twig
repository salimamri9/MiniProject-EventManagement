<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Reservation Confirmed</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.5; color: #222; background: #f7f7f7; padding: 24px;">
    <div style="max-width: 620px; margin: 0 auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
        <div style="background: #16a34a; color: #fff; padding: 16px 20px;">
            <h2 style="margin: 0; font-size: 20px;">Reservation confirmed</h2>
        </div>

        <div style="padding: 20px;">
            <p style="margin-top: 0;">Hello {{ reservation.fullName }},</p>
            <p>Your reservation has been confirmed by the admin team.</p>

            <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; padding: 14px; margin: 16px 0;">
                <p style="margin: 0 0 8px;"><strong>Event:</strong> {{ event.title }}</p>
                <p style="margin: 0 0 8px;"><strong>Date:</strong> {{ event.date|date('F j, Y \a\t g:i A') }}</p>
                <p style="margin: 0;"><strong>Location:</strong> {{ event.location }}</p>
            </div>

            <p style="margin-bottom: 0;">Thanks,<br>Events Management Team</p>
        </div>
    </div>
</body>
</html>
