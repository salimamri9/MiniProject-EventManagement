<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Events{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="{{ path('event_list') }}">EventHub</a>
            </div>
            <div class="nav-menu">
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard') }}" class="nav-link">Dashboard</a>
                        <a href="{{ path('admin_events') }}" class="nav-link">Events</a>
                        <a href="{{ path('admin_reservations') }}" class="nav-link">Reservations</a>
                        <a href="{{ path('admin_logout') }}" class="nav-link">Logout</a>
                    {% else %}
                        <a href="{{ path('event_list') }}" class="nav-link">Events</a>
                        <a href="{{ path('user_reservations') }}" class="nav-link">My Bookings</a>
                        <a href="{{ path('user_logout') }}" class="nav-link">Logout</a>
                    {% endif %}
                {% else %}
                    <a href="{{ path('event_list') }}" class="nav-link">Events</a>
                    <a href="{{ path('auth_login') }}" class="nav-link">Sign In</a>
                    <a href="{{ path('auth_register') }}" class="btn btn-primary btn-sm">Register</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="main-content">
        {% for message in app.flashes('success') %}
            <div class="container"><div class="alert alert-success">{{ message }}</div></div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="container"><div class="alert alert-error">{{ message }}</div></div>
        {% endfor %}
        {% block body %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="container">EventHub © {{ 'now'|date('Y') }}</div>
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>
