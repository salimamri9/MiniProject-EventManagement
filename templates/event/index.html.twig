{% extends 'base.html.twig' %}

{% block title %}Events{% endblock %}

{% block body %}
<div class="container">
    <div class="page-header">
        <h1>Upcoming Events</h1>
        <p>Find and book your next experience</p>
    </div>

    <div class="card mb-3">
        <form method="get" action="/" style="display: flex; gap: 0.75rem;">
            <input type="text" name="search" class="form-control" placeholder="Search events..." value="{{ search }}" style="flex: 1;">
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>

    {% if events is empty %}
        <div class="card text-center">
            <p style="color: var(--text-muted);">No events found.</p>
        </div>
    {% else %}
        <div class="events-grid">
            {% for event in events %}
                <div class="event-card" onclick="window.location.href='{{ path('event_detail', {id: event.id}) }}'">
                    <div class="event-image">📅</div>
                    <div class="event-content">
                        <h3 class="event-title">{{ event.title }}</h3>
                        <div class="event-date">{{ event.date|date('M j, Y • g:i A') }}</div>
                        <div class="event-location">{{ event.location }}</div>
                        <p class="event-description">{{ event.description }}</p>
                        <div class="event-footer">
                            {% set available = event.availableSeats %}
                            {% if available == 0 %}
                                <span class="seats-info full">Sold Out</span>
                            {% elseif available < 10 %}
                                <span class="seats-info low">{{ available }} left</span>
                            {% else %}
                                <span class="seats-info">{{ available }} available</span>
                            {% endif %}
                            <span class="btn btn-primary btn-sm">View →</span>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
